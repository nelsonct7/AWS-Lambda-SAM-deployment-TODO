{
  "name": "todo-back-end",
  "version": "1.0.0",
  "description": "Todo API with AWS Lambda and SAM",
  "main": "dist/handlers/auth.js",
  "scripts": {
    "build": "tsc",
    "package": "npm run build && sam package --s3-bucket <your-bucket> --output-template-file packaged.yaml",
    "deploy": "sam deploy --template-file packaged.yaml --stack-name todo-api --capabilities CAPABILITY_IAM",
    "local": "sam local start-api"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.5.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  }
}
